# OpenRouter API key — single key for all LLM calls (GPT-4o Mini + Claude Haiku)
# Get yours at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# App URL (used in OpenRouter headers)
APP_URL=https://aeo-studio.vercel.app

# Server config
PORT=3001
NODE_ENV=development

# Database
DB_PATH=./aeo-studio.db
